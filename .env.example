# ApplyPilot Environment Configuration
# Copy to ~/.applypilot/.env and fill in your values.

# LLM Providers — set one OR SEVERAL. When multiple are set, ApplyPilot
# round-robins across them and fails over on rate limits (429). Adding a second
# key is the easiest way to stop hitting limits.
GEMINI_API_KEY=           # Gemini 2.0 Flash (recommended, free tier, cheapest)
# OPENAI_API_KEY=         # OpenAI (default gpt-4o-mini)
# ANTHROPIC_API_KEY=      # Anthropic Claude (default claude-3-5-haiku-latest)
# LLM_URL=http://127.0.0.1:8080/v1  # Local OpenAI-compatible endpoint (llama.cpp, Ollama)

# Per-provider model overrides (optional)
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# LLM_MODEL=              # model for the local endpoint / OpenAI fallback
# LLM_PROVIDER_ORDER=gemini,openai,anthropic   # failover / round-robin order

# Networking & outreach (optional) — pick a contact provider:
HUNTER_API_KEY=          # Hunter.io — find contacts. FREE tier includes API access (recommended).
# APOLLO_API_KEY=        # Apollo.io — alternative; needs a PAID plan + MASTER key.
# NETWORKING_PROVIDER=hunter   # force hunter|apollo (default: first key present, hunter preferred)
# Gmail sending for outreach — two options:
#  1. OAuth (recommended, works with Workspace/@utexas.edu): `applypilot network --gmail-connect`
#     (needs a Google Cloud OAuth Desktop client JSON at ~/.applypilot/gmail_oauth_client.json;
#      pip install "applypilot[gmail]")
#  2. SMTP app password (personal gmail.com only):
# GMAIL_ADDRESS=
# GMAIL_APP_PASSWORD=
# OUTREACH_FROM_ADDRESS=  # send outreach FROM this address (must be a verified Gmail "Send mail as" alias)
# OUTREACH_FROM_NAME=    # display name on outgoing outreach
# OUTREACH_DAILY_LIMIT=20

# Auto-Apply (optional)
CAPSOLVER_API_KEY=        # For CAPTCHA solving during auto-apply

# Proxy (optional, for scraping)
# PROXY=host:port:user:pass
