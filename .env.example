# ApplyPilot Environment Configuration
# Copy to ~/.applypilot/.env and fill in your values.

# LLM Providers — set one OR SEVERAL. When multiple are set, ApplyPilot
# round-robins across them and fails over on rate limits (429). Adding a second
# key is the easiest way to stop hitting limits.
GEMINI_API_KEY=           # Gemini 2.0 Flash (recommended, free tier, cheapest)
# OPENAI_API_KEY=         # OpenAI (default gpt-4o-mini)
# ANTHROPIC_API_KEY=      # Anthropic Claude (default claude-3-5-haiku-latest)
# LLM_URL=http://127.0.0.1:8080/v1  # Local OpenAI-compatible endpoint (llama.cpp, Ollama)

# Per-provider model overrides (optional)
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# LLM_MODEL=              # model for the local endpoint / OpenAI fallback
# LLM_PROVIDER_ORDER=gemini,openai,anthropic   # failover / round-robin order

# Auto-Apply (optional)
CAPSOLVER_API_KEY=        # For CAPTCHA solving during auto-apply

# Proxy (optional, for scraping)
# PROXY=host:port:user:pass
